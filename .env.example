# Discord — create a NEW application at https://discord.com/developers/applications
#   Bot -> Token (Reset Token to reveal)        -> DISCORD_TOKEN
#   General Information -> Application ID         -> DISCORD_CLIENT_ID
#   Bot -> Privileged Gateway Intents: enable MESSAGE CONTENT and SERVER MEMBERS.
#   (Voice States is not privileged but is required — it's on by default.)
# This bot must be GUILD-installed (added to the server) so it can join voice channels.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Local services (see compose.yml)
TTS_URL=http://localhost:8011
STT_URL=http://localhost:8012

# Where the SQLite DB and uploaded voice samples live
DATA_DIR=./data

# Voice generation tuning
TTS_LANGUAGE=English
MAX_TTS_CHARS=300
